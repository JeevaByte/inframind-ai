{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Sample CloudFormation template for a VPC",
  "Resources": {
    "SampleVpc": {
      "Type": "AWS::EC2::VPC",
      "Properties": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true,
        "Tags": [
          {
            "Key": "Name",
            "Value": "InfraMindSampleVpc"
          }
        ]
      }
    }
  },
  "Outputs": {
    "VpcId": {
      "Description": "ID of the sample VPC",
      "Value": {
        "Ref": "SampleVpc"
      }
    }
  }
}