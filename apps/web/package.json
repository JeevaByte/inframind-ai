{
  "name": "@inframind/web",
  "version": "0.0.1",
  "private": true,
  "description": "infralint - Next.js web application",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
