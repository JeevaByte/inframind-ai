# =============================================================================
# InfraMind AI — Next.js web app environment variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# URL of the FastAPI analysis backend (used by the browser to call the API)
NEXT_PUBLIC_ANALYSIS_API_URL=http://localhost:8000

# Next.js public app URL (used for share links, OAuth callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
