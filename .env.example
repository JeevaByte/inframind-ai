# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=      # Set via GitHub Actions secret / local AWS profile
# AWS_SECRET_ACCESS_KEY=  # Set via GitHub Actions secret / local AWS profile

# ── API ───────────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:3001

# ── Frontend (Vercel / Next.js) ───────────────────────────────────────────────
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Secrets (never commit real values) ───────────────────────────────────────
# DATABASE_URL=
# OPENAI_API_KEY=
# JWT_SECRET=
