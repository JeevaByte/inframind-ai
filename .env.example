# =============================================================================
# InfraMind AI — environment variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# ── General ──────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ── API server ────────────────────────────────────────────────────────────────
PORT=3001

# PostgreSQL (Docker Compose default)
DATABASE_URL=postgresql://inframind:inframind@localhost:5432/inframind_dev

# Redis (Docker Compose default)
REDIS_URL=redis://localhost:6379

# JWT — use a long random string in production (openssl rand -hex 32)
JWT_SECRET=change-me-this-must-be-at-least-32-characters-long

# CORS — comma-separated origins allowed to call the API
CORS_ORIGIN=http://localhost:3000

# ── AI providers (optional — fill in at least one) ────────────────────────────
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=

# Python AI analysis backend
NEXT_PUBLIC_ANALYSIS_API_URL=http://localhost:8000

# ── Web app (Next.js public env vars) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
