# =============================================================================
# InfraMind AI — environment variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# Per-app examples:
#   backend/  → backend/.env.example
#   apps/web/ → apps/web/.env.local.example
# =============================================================================

# ── General ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── FastAPI analysis backend ──────────────────────────────────────────────────
# See backend/.env.example for the full list of backend env vars.
OPENAI_API_KEY=sk-...

# ── Web app (Next.js) ─────────────────────────────────────────────────────────
# URL of the FastAPI backend, accessible from the browser.
NEXT_PUBLIC_ANALYSIS_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
