# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# File storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=tf,tfvars,json,yaml,yml,hcl,template,dockerfile,Dockerfile

# Mock AI service
AI_SERVICE_URL=http://localhost:9000
AI_SERVICE_TIMEOUT_SECONDS=30
USE_MOCK_AI=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
