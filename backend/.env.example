# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# File storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=tf,tfvars,json,yaml,yml,hcl,template,dockerfile

# AI analysis
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=2
OPENAI_TEMPERATURE=0.1
USE_MOCK_AI=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
